# Docker Compose project name
COMPOSE_PROJECT_NAME=paperlesspilot

# Image tags
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:2.20.13
POSTGRES_IMAGE=docker.io/library/postgres:18
REDIS_IMAGE=docker.io/library/redis:8
TIKA_IMAGE=docker.io/apache/tika:3.3.0.0
GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:8.27

# Host / runtime
USERMAP_UID=1000
USERMAP_GID=1000
PAPERLESS_WEB_PORT=8000
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TIME_ZONE=Europe/Riga
PAPERLESS_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
GOTENBERG_API_TIMEOUT=120s

# Admin bootstrap
# Paperless will create this user automatically on startup if it does not exist.
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PAPERLESS_ADMIN_MAIL=admin@example.local

# Database
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=CHANGE_ME_DB_PASSWORD

# OCR / parsing
PAPERLESS_OCR_LANGUAGE=eng
# Space-separated extra Tesseract language packages to install in the Paperless container.
# Leave empty unless you need more than the languages already bundled by Paperless.
PAPERLESS_OCR_LANGUAGES=
# Date parser languages use dateparser language codes, not Tesseract language codes.
PAPERLESS_DATE_PARSER_LANGUAGES=en

# Consume behavior
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=false

# Optional filename format. Leave empty during pilot unless metadata is stable.
# Example:
# PAPERLESS_FILENAME_FORMAT={{ created_year }}/{{ correspondent }}/{{ title }}
PAPERLESS_FILENAME_FORMAT=
PAPERLESS_FILENAME_FORMAT_REMOVE_NONE=true

# Windows share host mount path.
# Mount your SMB share on the Linux host here, or replace with an absolute host path.
WINDOWS_SHARE_MOUNT=./source-mount

# Share sync behavior
SYNC_INTERVAL_SECONDS=300
SYNC_MAX_FILES_PER_RUN=250
REQUEUE_MISSING_AFTER_SECONDS=3600
# Comma-separated extension list. Empty means "all files".
SYNC_INCLUDE_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tif,.tiff,.bmp,.gif,.txt,.csv,.eml,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.odt,.ods,.odp,.rtf,.html,.htm,.xml,.md
