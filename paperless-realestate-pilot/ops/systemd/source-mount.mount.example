[Unit]
Description=Mount Windows share for Paperless pilot
After=network-online.target
Wants=network-online.target

[Mount]
What=//FILESERVER/SHARENAME
Where=/ABSOLUTE/PATH/TO/paperless-realestate-pilot/source-mount
Type=cifs
Options=credentials=/root/.paperless-share.credentials,vers=3.0,ro,iocharset=utf8,uid=1000,gid=1000,file_mode=0644,dir_mode=0755,noperm

[Install]
WantedBy=multi-user.target
