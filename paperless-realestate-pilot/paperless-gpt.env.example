# Optional paperless-gpt overlay settings
PAPERLESS_GPT_IMAGE=docker.io/icereed/paperless-gpt:v0.25.1
PAPERLESS_GPT_PORT=8080

PAPERLESS_BASE_URL=http://webserver:8000
PAPERLESS_PUBLIC_URL=http://localhost:8000
# Create this token from Paperless -> user menu -> My Profile
PAPERLESS_API_TOKEN=

MANUAL_TAG=paperless-gpt-manual
AUTO_TAG=paperless-gpt-auto

# Main LLM
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b

# OCR provider
OCR_PROVIDER=llm
VISION_LLM_PROVIDER=ollama
VISION_LLM_MODEL=minicpm-v
OLLAMA_HOST=http://host.docker.internal:11434

OCR_PROCESS_MODE=image
PDF_SKIP_EXISTING_OCR=false
OCR_LIMIT_PAGES=5

CREATE_LOCAL_HOCR=false
LOCAL_HOCR_PATH=/app/hocr
CREATE_LOCAL_PDF=false
LOCAL_PDF_PATH=/app/pdf

PDF_UPLOAD=false
PDF_REPLACE=false
PDF_COPY_METADATA=true
PDF_OCR_TAGGING=true
PDF_OCR_COMPLETE_TAG=paperless-gpt-ocr-complete

LOG_LEVEL=info
