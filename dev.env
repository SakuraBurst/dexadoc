# Source this file before running dexadoc locally:
#   source dev.env

# --- Database (matches docker-compose.dev.yml) ---
export PAPERLESS_DBHOST=localhost
export PAPERLESS_DBPORT=5432
export PAPERLESS_DBNAME=dexadoc
export PAPERLESS_DBUSER=dexadoc
export PAPERLESS_DBPASS=dexadoc

# --- Redis ---
export PAPERLESS_REDIS=redis://localhost:6379

# --- Tika / Gotenberg ---
export PAPERLESS_TIKA_ENABLED=1
export PAPERLESS_TIKA_ENDPOINT=http://localhost:9998
export PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://localhost:3000

# --- Django ---
export PAPERLESS_SECRET_KEY=dev-secret-not-for-production
export PAPERLESS_DEBUG=true
export PAPERLESS_URL=http://localhost:8000

# --- OCR ---
export PAPERLESS_OCR_LANGUAGE=rus+eng
export PAPERLESS_OCR_CLEAN=none

# --- Admin bootstrap (used by createsuperuser --noinput) ---
export DJANGO_SUPERUSER_USERNAME=admin
export DJANGO_SUPERUSER_PASSWORD=admin
export DJANGO_SUPERUSER_EMAIL=admin@localhost

# --- Dexadoc external sources ---
export DEXADOC_ENABLE_EXTERNAL_SOURCES=true
export DEXADOC_EXTERNAL_STORE_ARCHIVE_CACHE=false
export DEXADOC_EXTERNAL_ALLOW_UNINDEX=true
export DEXADOC_EXTERNAL_MAX_SCAN_WORKERS=2
